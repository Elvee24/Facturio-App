{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Facturio: Exportar pacotes",
			"type": "shell",
			"command": "./export_packages.sh",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": {
				"kind": "build",
				"isDefault": false
			},
			"presentation": {
				"reveal": "always",
				"panel": "shared",
				"clear": true
			},
			"problemMatcher": []
		},
		{
			"label": "Facturio: Build Linux/Android/Web",
			"type": "shell",
			"command": "./build_linux.sh",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"isBackground": false,
			"presentation": {
				"reveal": "always",
				"panel": "shared",
				"clear": true
			},
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Facturio: Build macOS/iOS/Android/Web",
			"type": "shell",
			"command": "./build_macos.sh",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"isBackground": false,
			"presentation": {
				"reveal": "always",
				"panel": "shared",
				"clear": true
			},
			"problemMatcher": []
		},
		{
			"label": "Facturio: Build Windows/Android/Web",
			"type": "shell",
			"command": "powershell -ExecutionPolicy Bypass -File ./build_windows.ps1",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"isBackground": false,
			"presentation": {
				"reveal": "always",
				"panel": "shared",
				"clear": true
			},
			"problemMatcher": []
		}
	]
}